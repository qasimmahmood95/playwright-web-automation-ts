{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["node"],
    "paths": {
      "@/pages/*": ["./pages/*"],
      "@/fixtures": ["./fixtures/index"],
      "@/fixtures/*": ["./fixtures/*"],
      "@/test-data/*": ["./test-data/*"],
      "@/utils/*": ["./utils/*"],
      "@/config/*": ["./config/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "fixtures/**/*.ts",
    "test-data/**/*.ts",
    "utils/**/*.ts",
    "config/**/*.ts",
    "*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
