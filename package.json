{
  "name": "playwright-web-automation-ts",
  "version": "1.0.0",
  "description": "End-to-end test suite for saucedemo.com built with Playwright and TypeScript",
  "author": "Qasim Mahmood",
  "license": "ISC",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "test:visual:update": "playwright test --grep @visual --update-snapshots",
    "test:performance": "playwright test --grep @performance",
    "test:docker": "docker build -t playwright-web-automation-ts . && docker run --rm playwright-web-automation-ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.3",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-plugin-playwright": "^2.10.5",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "typescript-eslint": "^8.63.0"
  }
}
